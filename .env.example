SERVER_PORT=8080
NOTIFIER_ADDR=notifier:50051

DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=release_notifier
DB_SSLMODE=disable

GITHUB_TOKEN=

SCAN_INTERVAL=5m

# Required. Startup fails when unset/empty so a config mistake cannot expose
# /api/subscriptions to the public internet.
API_KEY=change-me

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=10m

TRUSTED_PROXY=false
LOG_LEVEL=info
SERVICE_NAME=github-release-notifier

# Notification service env (docker-compose sets these on the notifier); for a bare-process run set notifier DB_* so it does not migrate the monolith DB:
#   DB_HOST=localhost DB_PORT=5434 DB_NAME=notification
GRPC_ADDR=:50051
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
BASE_URL=http://localhost:8080
